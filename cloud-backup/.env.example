# Elite Memories — MEGA Sync configuration
# Copy this file to .env and fill in the values.
# Never commit .env to git.

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# MEGA account credentials (dedicated account recommended — not your personal one)
MEGA_EMAIL=your-mega-email@example.com
MEGA_PASSWORD=your-mega-password-here

# Remote folder inside your MEGA account where files will be stored.
# Defaults to /Elite Memories if not set.
# MEGA_REMOTE_FOLDER=/Elite Memories
